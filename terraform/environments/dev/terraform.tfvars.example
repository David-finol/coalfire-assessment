# Example terraform.tfvars file for dev environment
# Copy this to terraform.tfvars and update values as needed

aws_region  = "us-east-1"
environment = "dev"

# Network Configuration
vpc_cidr                 = "10.1.0.0/16"
application_subnet_cidrs = ["10.1.1.0/24", "10.1.2.0/24"]
management_subnet_cidr   = "10.1.3.0/24"
backend_subnet_cidrs     = ["10.1.4.0/24", "10.1.5.0/24"]

# Compute Configuration
instance_type            = "t2.micro"
asg_min_size             = 2
asg_max_size             = 6
asg_desired_capacity     = 2

# Security Configuration
# IMPORTANT: Update this to your actual IP address or network
# Example: ["203.0.113.0/32"] for a specific IP
# Example: ["203.0.113.0/24"] for a network
management_access_cidrs  = ["0.0.0.0/32"]
